{
  "name": "expense-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "fmt": "prettier --write .",
    "postinstall": "pnpm simple-git-hooks"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "pnpm exec prettier --write",
      "pnpm exec eslint --fix --cache"
    ],
    "*.{html,css,json,md}": [
      "pnpm exec prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "eslint": "^9.39.4",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.8.20"
  }
}
